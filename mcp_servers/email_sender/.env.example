# Gmail API Configuration
GMAIL_CREDENTIALS_PATH=/path/to/.credentials/gmail-credentials.json
GMAIL_TOKEN_PATH=/path/to/.credentials/gmail-token.json

# Gmail API Scopes (for sending emails)
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.compose

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_BASE=1000  # milliseconds (1s, 2s, 4s exponential backoff)

# Logging Configuration
LOG_LEVEL=info  # Options: debug, info, warn, error
EMAIL_LOG_PATH=/Logs/email_sent.log
