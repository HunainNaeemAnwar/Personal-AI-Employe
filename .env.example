# Obsidian Vault Configuration
VAULT_PATH=/path/to/your/AI_Employee_Vault

# Gmail Watcher Configuration
GMAIL_CREDENTIALS_PATH=/path/to/.credentials/gmail-credentials.json
GMAIL_TOKEN_PATH=/path/to/.credentials/gmail-token.json
GMAIL_QUERY=is:unread is:important
# Gmail API scopes for Silver tier (reading + sending)
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.compose

# File System Watcher Configuration
WATCH_DIRECTORY=/path/to/your/dropbox/folder
FILE_EXTENSIONS=*  # Or specify: .pdf,.docx,.xlsx

# LinkedIn Watcher Configuration (Silver Tier)
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_POLLING_INTERVAL=300  # seconds (5 minutes)
LINKEDIN_RATE_LIMIT_REQUESTS=100  # requests per hour
LINKEDIN_RATE_LIMIT_WINDOW=3600  # seconds (1 hour)

# Scheduling Configuration (Silver Tier)
SCHEDULER_TYPE=cron  # Options: cron (Linux/Mac) or task_scheduler (Windows)
SCHEDULED_TASKS_CONFIG=scheduled_tasks.yaml
SCHEDULER_LOG_PATH=/Logs/scheduled_tasks.log

# State Management Configuration (Silver Tier)
STATE_DB_PATH=state.db
STATE_BACKUP_INTERVAL=86400  # seconds (24 hours)
STATE_HEALTH_CHECK_INTERVAL=300  # seconds (5 minutes)

# Orchestrator Configuration (Silver Tier)
ORCHESTRATOR_HEALTH_CHECK_INTERVAL=60  # seconds
ORCHESTRATOR_RESTART_DELAY=5  # seconds
ORCHESTRATOR_LOG_PATH=/Logs/orchestrator.log

# Approval Workflow Configuration (Silver Tier)
APPROVAL_REMINDER_INTERVAL=86400  # seconds (24 hours)
APPROVAL_LOG_PATH=/Logs/approvals.log
