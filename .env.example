# =============================================================================
# Personal AI Employee - Environment Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
#
# [REQUIRED] = Must set  |  [OPTIONAL] = Has defaults
# =============================================================================

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ [REQUIRED] CORE CONFIGURATION                                           │
# └─────────────────────────────────────────────────────────────────────────┘

# Obsidian vault path (where tasks/logs are stored)
VAULT_PATH=/path/to/your/AI_Employee_Vault

# State database path (prevents duplicate task processing)
STATE_DB_PATH=state.db

# Folder to monitor for new files (File System Watcher)
WATCH_DIRECTORY=/path/to/your/dropbox/folder

# Which watchers to run: gmail, filesystem, linkedin
ORCHESTRATOR_WATCHERS=filesystem,linkedin


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ [REQUIRED] LINKEDIN WATCHER (if enabled in ORCHESTRATOR_WATCHERS)      │
# └─────────────────────────────────────────────────────────────────────────┘

# LinkedIn login credentials (uses Selenium automation)
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ [OPTIONAL] GMAIL WATCHER (if enabled in ORCHESTRATOR_WATCHERS)         │
# └─────────────────────────────────────────────────────────────────────────┘

# Gmail OAuth2 credentials (from Google Cloud Console)
# GMAIL_CREDENTIALS_PATH=/home/user/.credentials/gmail-credentials.json
# GMAIL_TOKEN_PATH=/home/user/.credentials/gmail-token.json

# Email filter query
# GMAIL_QUERY=is:unread is:important


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ [OPTIONAL] TUNING (Defaults work for most cases)                       │
# └─────────────────────────────────────────────────────────────────────────┘

# File watcher: Which extensions to monitor (* = all)
# FILE_EXTENSIONS=*

# File watcher: Check interval in seconds (default: 5)
# FILESYSTEM_POLLING_INTERVAL=5

# LinkedIn: Check interval in seconds (default: 300 = 5 min)
# LINKEDIN_POLLING_INTERVAL=300

# LinkedIn: Rate limit (default: 100 requests/hour)
# LINKEDIN_RATE_LIMIT_REQUESTS=100
# LINKEDIN_RATE_LIMIT_WINDOW=3600

# Orchestrator: Health check interval (default: 60 seconds)
# ORCHESTRATOR_HEALTH_CHECK_INTERVAL=60

# Orchestrator: Restart delay (default: 5 seconds)
# ORCHESTRATOR_RESTART_DELAY=5

# State DB: Backup interval (default: 86400 = 24 hours)
# STATE_BACKUP_INTERVAL=86400

# State DB: Health check (default: 300 = 5 minutes)
# STATE_HEALTH_CHECK_INTERVAL=300

# Approval: Reminder interval (default: 86400 = 24 hours)
# APPROVAL_REMINDER_INTERVAL=86400


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ QUICK START                                                             │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Minimum setup (File + LinkedIn watchers):
#   VAULT_PATH=/your/vault
#   WATCH_DIRECTORY=/your/folder
#   STATE_DB_PATH=state.db
#   ORCHESTRATOR_WATCHERS=filesystem,linkedin
#   LINKEDIN_USERNAME=your@email.com
#   LINKEDIN_PASSWORD=your_password
#
# With Gmail watcher:
#   Add: ORCHESTRATOR_WATCHERS=gmail,filesystem,linkedin
#   Add: GMAIL_CREDENTIALS_PATH, GMAIL_TOKEN_PATH
#
# =============================================================================
