{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/HunainNaeemAnwar/Personal-AI-Employe/schemas/watcher-state.json",
  "title": "Watcher State Schema",
  "description": "JSON schema for SQLite state database used by watchers to prevent duplicate task creation",
  "type": "object",
  "required": ["version", "processed_items"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version for migration tracking",
      "minimum": 1,
      "example": 1
    },
    "processed_items": {
      "type": "array",
      "description": "List of all processed items across all watchers",
      "items": {
        "$ref": "#/definitions/ProcessedItem"
      }
    }
  },
  "definitions": {
    "ProcessedItem": {
      "type": "object",
      "required": ["id", "source", "source_id", "timestamp", "status", "created_at"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "Unique identifier (auto-increment)",
          "minimum": 1,
          "example": 1
        },
        "source": {
          "type": "string",
          "description": "Source type of the item",
          "enum": ["gmail", "filesystem", "linkedin"],
          "example": "gmail"
        },
        "source_id": {
          "type": "string",
          "description": "Source-specific identifier (email ID, file path, LinkedIn message ID)",
          "minLength": 1,
          "maxLength": 500,
          "examples": [
            "18d4f2a3b5c6e7f8",
            "/home/hunain/Dropbox/inbox/invoice.pdf",
            "MSG-789DEF"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when item was first detected",
          "example": "2026-03-09T14:30:00Z"
        },
        "status": {
          "type": "string",
          "description": "Processing status of the item",
          "enum": ["pending", "processed", "failed"],
          "example": "processed"
        },
        "task_file_path": {
          "type": ["string", "null"],
          "description": "Relative path to created task file in vault (null if not yet created)",
          "pattern": "^[A-Za-z_]+/[A-Z_]+_[0-9TZ]+_[a-z0-9-]+\\.md$",
          "examples": [
            "Needs_Action/EMAIL_20260309T143000Z_client-inquiry.md",
            "Needs_Action/LINKEDIN_MSG_20260309T160000Z_john-doe-inquiry.md",
            null
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when record was created in database",
          "example": "2026-03-09T14:30:05Z"
        },
        "error_message": {
          "type": ["string", "null"],
          "description": "Error details if status is 'failed'",
          "maxLength": 1000,
          "examples": [
            "Gmail API quota exceeded",
            "File not readable: Permission denied",
            null
          ]
        },
        "retry_count": {
          "type": "integer",
          "description": "Number of retry attempts for failed items",
          "minimum": 0,
          "maximum": 3,
          "default": 0,
          "example": 0
        }
      },
      "additionalProperties": false
    },
    "StateQuery": {
      "type": "object",
      "description": "Query parameters for checking if item was already processed",
      "required": ["source", "source_id"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["gmail", "filesystem", "linkedin"]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "StateInsert": {
      "type": "object",
      "description": "Data for inserting new processed item",
      "required": ["source", "source_id", "timestamp", "status"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["gmail", "filesystem", "linkedin"]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processed", "failed"]
        },
        "task_file_path": {
          "type": ["string", "null"]
        },
        "error_message": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "StateUpdate": {
      "type": "object",
      "description": "Data for updating existing processed item",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processed", "failed"]
        },
        "task_file_path": {
          "type": ["string", "null"]
        },
        "error_message": {
          "type": ["string", "null"]
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "version": 1,
      "processed_items": [
        {
          "id": 1,
          "source": "gmail",
          "source_id": "18d4f2a3b5c6e7f8",
          "timestamp": "2026-03-09T14:30:00Z",
          "status": "processed",
          "task_file_path": "Needs_Action/EMAIL_20260309T143000Z_client-inquiry.md",
          "created_at": "2026-03-09T14:30:05Z",
          "error_message": null,
          "retry_count": 0
        },
        {
          "id": 2,
          "source": "linkedin",
          "source_id": "MSG-789DEF",
          "timestamp": "2026-03-09T16:00:00Z",
          "status": "processed",
          "task_file_path": "Needs_Action/LINKEDIN_MSG_20260309T160000Z_john-doe-inquiry.md",
          "created_at": "2026-03-09T16:00:05Z",
          "error_message": null,
          "retry_count": 0
        },
        {
          "id": 3,
          "source": "filesystem",
          "source_id": "/home/hunain/Dropbox/inbox/invoice.pdf",
          "timestamp": "2026-03-09T18:00:00Z",
          "status": "failed",
          "task_file_path": null,
          "created_at": "2026-03-09T18:00:05Z",
          "error_message": "File not readable: Permission denied",
          "retry_count": 1
        }
      ]
    }
  ]
}
